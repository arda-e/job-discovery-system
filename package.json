{
  "name": "job-discovery-system",
  "version": "0.1.0",
  "private": true,
  "description": "Serverless job discovery system scaffold.",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "package:lambda": "rm -rf build/lambda && mkdir -p build/lambda && cp -R dist/. build/lambda/ && cp package.json package-lock.json build/lambda/",
    "test": "jest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.916.0",
    "exa-js": "^2.11.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.3"
  }
}
